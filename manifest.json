{
  "update_url": "https://clients2.google.com/service/update2/crx",
  
  "manifest_version": 3,
  "name": "Steam Friends Tracker Pro",
  "version": "2.0",
  "description": "Трекер друзей с авто-мониторингом через Steam API, статусами и избранным",
  "permissions": ["storage", "notifications", "alarms"],
  "host_permissions": [
    "https://steamcommunity.com/profiles/*/friends",
    "https://steamcommunity.com/id/*/friends",
    "https://api.steampowered.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Steam Friends Tracker Pro",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": [
      "https://steamcommunity.com/profiles/*/friends",
      "https://steamcommunity.com/id/*/friends"
    ],
    "js": ["content.js"],
    "run_at": "document_idle",
    "all_frames": false
  }],
  "web_accessible_resources": [{
    "resources": ["*.png", "*.ico", "*.mp4", "*.js"],
    "matches": ["https://steamcommunity.com/*"]
  }]
}