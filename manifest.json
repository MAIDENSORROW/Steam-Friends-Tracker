{
  "manifest_version": 3,
  "name": "Friends Tracker Pro",
  "version": "4.0",
  "description": "Трекер друзей Steam с авто-обновлением и API интеграцией",
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "identity",
    "tabs"
  ],
  "host_permissions": [
    "https://api.steampowered.com/*",
    "https://steamcommunity.com/*",
    "https://steamcommunity.com/openid/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "web_accessible_resources": [{
    "resources": ["*.png", "*.ico", "*.mp4", "*.js", "*.html"],
    "matches": ["https://steamcommunity.com/*"]
  }]
}