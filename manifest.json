{
  "manifest_version": 3,
  "name": "Steam Friends Tracker",
  "version": "5.1",
  "description": "Отслеживает изменения в списке друзей Steam",
  "permissions": [
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "*://steamcommunity.com/*",
    "*://*.steamstatic.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Steam Friends Tracker",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://steamcommunity.com/*/friends*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon.png",
        "*.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}