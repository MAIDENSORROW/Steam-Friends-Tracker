{
  "manifest_version": 3,
  "name": "Steam Friends Tracker",
  "version": "10.0",
  "description": "Отслеживает друзей + Видео фон + Радио",
  "permissions": ["storage", "notifications", "offscreen"],
  "host_permissions": [
    "https://steamcommunity.com/*",
    "https://*.steamstatic.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Steam Friends Tracker",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://steamcommunity.com/*/friends"],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "web_accessible_resources": [{
    "resources": ["*.png","*.ico", "*.mp4", "*.js"],
    "matches": ["<all_urls>"]
  }]
}